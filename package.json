{
  "name": "holiday-app",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "pnpm type-check && vite build",
    "preview": "vite preview",
    "build-only": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@fontsource/roboto-mono": "^5.2.8",
    "@mdi/font": "7.4.47",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@intellectronica/ruler": "^0.3.37",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.4",
    "eslint-config-vuetify": "^4.3.4",
    "jsdom": "^29.0.2",
    "sass-embedded": "^1.98.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "unplugin-fonts": {
      "vite": "^8.0.0"
    }
  }
}
